# ── LLM provider credentials ────────────────────────────────────────────────
# The router tries providers in order. Set at least one. All have free tiers.
#
# Tier 1 (recommended): Hugging Face Inference Providers
#   - Sign up at https://huggingface.co/join (no credit card)
#   - Create a token at https://huggingface.co/settings/tokens (read scope is enough)
#   - One token unlocks 100+ open-weight models across Cerebras, Groq, Together, etc.
HF_TOKEN=

# Tier 2 (fallback): Google Gemini
#   - Free tier: 1500 requests/day on gemini-2.0-flash, no credit card
#   - Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Tier 3 (fully offline): Ollama
#   - Install from https://ollama.com — no key needed
#   - Pull a model: `ollama pull llama3.2:3b`
OLLAMA_BASE_URL=http://localhost:11434

# ── Model selection (optional — defaults work) ──────────────────────────────
# Override the model id used for each provider. The HF model uses the OpenAI-
# compatible Inference Providers router at https://router.huggingface.co/v1.
# LRD_HF_MODEL=openai/openai/gpt-oss-20b:cheapest
# LRD_GEMINI_MODEL=gemini/gemini-2.0-flash
# LRD_OLLAMA_MODEL=ollama/llama3.2:3b

# ── Judge consensus (multi-call majority vote) ──────────────────────────────
# 1 = single call (cheapest), 3 = N=3 majority vote (recommended for production
# alerts — dampens judge variance at 3× the token cost). 5 / 7 also supported.
# LRD_JUDGE_CONSENSUS_N=1

# ── Cost estimation ($ per 1M tokens; defaults to $0 = free tier) ───────────
# Set these if you swap to a paid model so the report shows real spend per run.
# LRD_COST_INPUT_USD=0.0
# LRD_COST_OUTPUT_USD=0.0

# ── Webhook notifications (optional) ────────────────────────────────────────
# Platform auto-detected from URL. Leave blank to disable alerts.
#   Slack:        https://hooks.slack.com/services/...
#   Google Chat:  https://chat.googleapis.com/v1/spaces/.../messages?...
#   Discord:      https://discord.com/api/webhooks/...
#   Generic JSON: any other HTTPS endpoint accepting POST
WEBHOOK_URL=

# Optional override — force a specific platform formatter
# WEBHOOK_PLATFORM=slack | google_chat | discord | generic

# ── Runtime configuration ───────────────────────────────────────────────────
LRD_LOG_LEVEL=INFO
LRD_CONCURRENCY=10
